/target
**/target/
**/*.rs.bk
Cargo.lock.bak
# Fetched oracle payloads are reproduced from provenance; only manifests + checksums
# are committed. (The small F1 constants JSON is committed; large payloads are not.)
/oracles/**/payload/
# Local Lean/F1 build tree created by `cargo xtask atlas-extract`.
/.f1-build
.DS_Store

# LaTeX compilation intermediates
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.toc
*.synctex.gz
*.bbl
*.blg
*.4tc
*.4ct
*.idv
*.lg
*.tmp
*.xref
*.dvi

# Built paper PDFs (CI builds these; only paper PDFs are ignored, not repo-wide *.pdf)
docs/paper/*.pdf
docs/paper/**/*.pdf

# Pandoc / HTML outputs
public/
docs/paper/index.html
docs/paper/main.html
docs/paper/main.css
